# The chain switcher caps the wagmi cluster to the 2.x line via package.json
# "overrides" (to match @reown/appkit-adapter-wagmi and avoid wagmi 3.x pulling
# viem/tempo/* paths the resolved viem does not expose). npm's strict peer
# resolver trips on the override even though every peer range is satisfied, so
# we install in legacy peer mode. Peers needed at build time (mermaid,
# typescript) are therefore declared explicitly in package.json devDependencies.
legacy-peer-deps=true
