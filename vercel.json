{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/nox-protocol/:path*",
      "destination": "/:path*",
      "statusCode": 301
    },
    {
      "source": "/nox-protocol",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/robots.txt",
      "destination": "/robots-prod.txt",
      "has": [{ "type": "host", "value": "docs.noxprotocol.io" }]
    },
    {
      "source": "/robots.txt",
      "destination": "/robots-dev.txt"
    }
  ]
}
